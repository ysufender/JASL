pub let Enum = enum {
    Field1,
    Field2,
    Field3,
    Field4,
};

pub let Struct = struct {
    field1: bool,
    field2: Enum,
    other: void,
};

pub let Struct2 = struct {
    field1: bool,
    field2: Enum,
    other: void,
};

pub let Union = union(enum) {
    field1: struct { },
    field2: bool,
    field3: i32,
};

let a: Enum = @Field1;

let b: Enum = (@Field1);
let c = Enum::Field1;
let d: Enum = @Field1;

let f: Struct = (true, @Field1, ());
let g: Struct = (true, Enum::Field1, ());
let h: Struct = (true, Enum(@Field1), ());
let j: Struct = (true, Enum(Enum::Field1), ());

pub let e: Struct = switch Union(@field1) {
    @field1 -> |something| something,
    else -> false,
};

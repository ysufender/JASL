pub let Enum = enum {
    Field1,
    Field2,
    Field3,
    Field4,
};

pub let Struct = struct {
    field1: bool,
    field2: Enum,
    other: void,
};

pub let Struct2 = struct {
    field1: bool,
    field2: Enum,
    other: void,
};

pub let Union = union(enum) {
    field1: bool,
    field2: bool,
    field3: i32,
};

pub let main = switch (a) {
    @Field1 -> Struct(false, @Field1),
    @Field2 -> Struct2(true, @Field2),
    else -> unreachable(),
};

let a: i::Enum = @Field1;

let b: i::Enum = (@Field1);

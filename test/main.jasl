import std::iterator as iterator;
import std;

let Main = std::Result(void, std::ErrorCode);
let Pair = std::Pair(u32, u32);

let Repeat = iterator::Repeat;
let Select = iterator::Map(u32);
let Series = iterator::Fold(Pair);
let Collect = iterator::Collect;

let main = fn () -> Main {
    let result = Repeat(15)
        .pipe(Series).with(fn |acc, _| (acc.second, acc.first + acc.second), (0, 1))
        .pipe(Select).with(fn |n| n.second)
        .pipe(Collect)
        .collect();

    return Main(@Ok);
};

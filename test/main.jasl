import std;
import experimental::borrowchecker as BC;

let Main = std::Result(void, std::ErrorCode);

let new = BC::new;
let Value = BC::Value;

let main = fn () -> Main {
    let someInt = new(u32, 54);
    someFuncBorrow(someInt.borrow());
    someFunc(someInt.own());

    return Main(@Ok);
};

let someFunc = fn (value: Value(u32)) -> Value(u32) {
    value.Owned();
    return new(u32, value + 15);
};

let someFuncBorrow = fn (value: Value(u32)) -> Value(u32) {
    value.Borrowed();
    return new(u32, value + 10);
};

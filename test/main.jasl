import std::iterator as iterator;
import std;

let Main = std::Result(void, std::ErrorCode);

let Range = iterator::Range;
let Filter = iterator::Filter;

let main = fn () -> Main {
    let result = Range(u32)
        .init(0, 150, 1)
        .pipe(Filter(u32), u32).initp(fn (elem: u32) -> bool { return elem <= 10; })
        .pipe();

    return Main(@Ok, ());
};

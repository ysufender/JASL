pub let TestUnion = union(enum) {
    field1: TestEnum,
    field2: TestStruct,
    
    pub let someDef = struct {
        pub let someInnerDef = TestStruct;
    };
};

pub let TestStruct = struct {
    pub let publicDef = TestUnion::someDef::someInnerDef::publicDef;
    let privateDef = true;

    someField: bool,
};

pub let TestEnum = enum {
    SomeField,
};

import std::iterator as I;
import std::math as M;

let Main = std::Result(void, std::ErrorCode);

let main = fn () -> Main {
    _ = integrate(fn |x| x * x, 0.0, 4.0, M::Epsilon);

    return Main(@Ok);
};

let integrate = fn (
    func: *fn (float) -> float,
    from: float,
    to: float,
    dx: float,
) -> float {
    let Interval = I::Range(float);
    let Graph = I::Map(float);
    let Integral = I::Map(float);
    let Sum = I::Fold(float);

    return I::Range(float)
        .init(from, to, dx)
        .pipe(Graph).with(func)
        .pipe(Integral).with(fn |y| y * dx)
        .pipe(Sum).with(fn |acc, v| acc + v);
};

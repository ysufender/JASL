    Public Symbols:
        MemberInfo,
        TraitInfo,
       VerifyTrait 
    Description:
        Defines helper utilities for creating traits with ease.
*/
 
import builtin as b;
import builtin::type as t;
import std::iterator as i;
import std::functional as f;
import std::collections as c;

pub let MemberInfo = union(enum) {
    Field: t::FieldInfo,
    Definition: t::FieldInfo,
};

pub let TraitInfo = struct {
    name: []u8,
    members: []MemberInfo,
};

pub let VerifyTrait = fn (Trait: TraitInfo, On: type) -> type {
    let typeInfo = switch b::typeInfo(On) {
        @Struct -> |s| s,
        else -> b::compileError("{s} trait can only be implemented on structs.", (Trait.name)),
    };

    let i: mut u32 = 0;
    while i < Trait.members.len {
        defer i = i + 1;
        let member = Trait.members[i];
        switch member {
            @Field -> |field| {
                if 
                    !b::hasField(On, field.name)
                    or !std::Equible::Generic(t::FieldInfo, field, typeInfo.fields[b::fieldIndex(On, field.name)]) {
                    b::compileError("Couldn't find '{s}' trait field '{b} {s}: {any}' in '{s}'",
                        (Trait.name, field.public, field.name, field.valueType, typeInfo.name)
                    );
                }
            }

            @Definition -> |def| {
                if 
                    !b::hasDef(On, def.name)
                    or !std::Equible::Generic(t::FieldInfo, def, typeInfo.definitions[b::definitionIndex(On, def.name)]) {
                    b::compileError("Couldn't find '{s}' trait definition '{b} {s}: {any}' in '{s}'",
                        (Trait.name, def.public, def.name, def.valueType, typeInfo.definitions[b::definitionIndex(On, def.name)].name)
                    );
                }
            }
        }
    }

    return On;
};

pub let CheckTrait = fn (Trait: TraitInfo, On: type) -> bool {
    if b::typeInfo(On).tag != @Struct {
        return false;
    }

    let typeInfo = b::typeInfo(On).Struct;

    let i: mut u32 = 0;
    while i < Trait.members.len {
        defer i = i + 1;
        let member = Trait.members[i];
        switch member {
            @Field -> |field| {
                if 
                    !b::hasField(On, field.name)
                    or !std::Equible::Generic(t::FieldInfo, field, typeInfo.fields[b::fieldIndex(On, field.name)]) {
                        return false;
                }
            }

            @Definition -> |def| {
                if 
                    !b::hasDef(On, def.name)
                    or !std::Equible::Generic(t::FieldInfo, def, typeInfo.definitions[b::definitionIndex(On, def.name)]) {
                        return false;
                }
            }
        }
    }

    return true;
};

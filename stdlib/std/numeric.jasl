    DISCLAIMER:
        The traits and conventions mentioned in this document
        are to be obeyed, otherwise neither JASL STDLib nor the
        compiler can guarantee a well defined program.

    Name:
        std::numeric
    Public Symbols:
        Integer,
        Numeric,
        Signed,
        Unsigned,
        Epsilon,
    Description:
        Contains definitions for mathematical operations. For more
        "theoric" side of the numbers, see std::numeric.
*/
import builtin as B;
import std::math as M;
import std::comptime as CT;

pub let Integer = struct {
    let Check = fn (T: type) -> bool {
        return B::typeInfo(T).tag == @Integer;
    };
    
    let Trait = fn (T: type) -> type {
        if !Check(T) {
            B::compileError("Given type does not satisfy the Integer traits.", ());
        }

        return T;
    };
};

pub let Numeric = struct {
    let Check = fn (T: type) -> bool {
        return Integer::Check(T) or T == float;
    };

    let Trait = fn (T: type) -> type {
        if !Check(T) {
            B::compileError("Given type does not satisfy the Numeric traits.", ());
        }

        return T;
    };
};

pub let Signed = struct {
    let Check = fn (T: type) -> bool {
        return switch B::typeInfo(T) {
            @Integer -> |i| i.signed,
            @Float -> true,
            else -> false,
        };
    }; 

    let Trait = fn (T: type) -> type {
        if !Check(T) {
            B::compileError("Given type does not satisfy the Signed traits.", ());
        }

        return T;
    };
};

pub let Unsigned = struct {
    let Check = fn (T: type) -> bool {
        return !Signed::Check(T);
    }; 

    let Trait = fn (T: type) -> type {
        if !Check(T) {
            B::compileError("Given type does not satisfy the Unsigned traits.", ());
        }

        return T;
    };
};

pub let Limits = fn (T: type) -> type {
    return struct {
        pub let Max = switch B::typeInfo(Numeric::Check(T)) {
            @Integer -> |i|
                if (i.signed) M::pow(2, i.size - 1) - 1
                else M::pow(2, i.size) - 1,
            @Float -> 340282350000000000000000000000000000000.0,
            else -> B::unreachable(),
        };

        pub let Min = switch B::typeInfo(Numeric(T)) {
            @Integer -> |i|
                if (i.signed) -M::pow(2, i.size - 1)
                else 0,
            @Float -> -Max(T),
            else -> B::unreachable(),
        };
    };
};

pub let Addable = struct {
    let Self = B::this();

    pub let Check = fn (T: type) -> bool {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "add", *fn (T, T) -> T)),
            ),
        );

        return switch B::typeInfo(T) {
            @Integer -> true,
            @Float -> true,
            @Struct -> CT::CheckTrait(trait, T),
            else -> false,
        };
    };

    pub let Trait = fn (T: type) -> type {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "add", *fn (T, T) -> T)),
            ),
        );

        return switch B::typeInfo(T) {
            @Integer -> T,
            @Float -> T,
            @Struct -> CT::VerifyTrait(trait, T),
            else -> B::compileError("Given type '{any}' is not addable.", (T)),
        };
    };

    pub let Generic = fn (T: type, lhs: Trait(T), rhs: Trait(T)) -> T {
        return switch B::typeInfo(T) {
            @Struct -> lhs.add(rhs),
            else -> lhs + rhs,
        };
    };
};

pub let Negatable = struct {
    let Self = B::this();

    pub let Check = fn (T: type) -> bool {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "neg", *fn (T) -> T)),
            ),
        );

        return switch B::typeInfo(T) {
            @Integer -> |i| i.signed,
            @Float -> true,
            @Struct -> CT::CheckTrait(trait, T),
            else -> false,
        };
    };

    pub let Trait = fn (T: type) -> type {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "neg", *fn (T) -> T)),
            ),
        );

        return switch B::typeInfo(T) {
            @Integer -> |i|
                if (i.signed) T
                else B::compileError("Negation on unsigned integers is not allowed.", ()),
            @Float -> T,
            @Struct -> CT::VerifyTrait(trait, T),
            else -> B::compileError("Given type '{any}' is not negatable.", (T)),
        };
    };

    pub let Generic = fn (T: type, n: Trait(T)) -> T {
        return switch B::typeInfo(T) {
            @Struct -> n.neg(),
            else -> -n,
        };
    };
};

pub let Subtractable = struct {
    let Self = B::this();

    pub let Check = fn (T: type) -> bool {
        return Negatable::Check(T) and Addable::Check(T);
    };

    pub let Trait = fn (T: type) -> type {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "sub", *fn (T, T) -> T)),
            ),
        );

        if CT::CheckTrait(trait, T) {
            return T;
        }

        if Check(T) {
            return T;
        }

        B::compileError("A subtractable type must either be both negatable and addable, or implement 'sub' method.", ());
    };

    pub let Generic = fn (T: type, lhs: Trait(T), rhs: Trait(T)) -> T {
        let trait = CT::TraitInfo(
            B::typeInfo(Self).Struct.name, (
                CT::MemberInfo(@Definition, (true, "sub", *fn (T, T) -> T)),
            ),
        );

        return switch B::typeInfo(T) {
            @Struct ->
                if (CT::CheckTrait(T)) lhs.sub(rhs)
                else lhs.add(rhs.neg()),
            else -> lhs - rhs,
        };
    };
};

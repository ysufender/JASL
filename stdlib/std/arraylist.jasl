import std::mem;
import std::math;
import builtin;

let Allocator = std::mem::Allocator;

pub let ArrayList = fn (T: type) -> type {
    return struct {
        let Self = builtin::this();

        pub items: mut []mut T,
        capacity: u32,
        allocator: Allocator,

        pub let init(allocator: Allocator, capacity: u32) -> Self {
            let items = allocator.alloc(T, std::math::max(32, capacity));

            return (items[0..0], items.len, allocator);
        };
    };
};

import builtin;
import std::comptime;

pub let assert = fn (cnd: bool, msg: []u8) -> void {
    if !cnd {
        // TODO: Message error when IO is implemented
        builtin::unreachable();
    }
};

// TODO: function tags for force comptime
pub let staticAssert = fn (cnd: bool) -> void {
    if !cnd {
        builtin::compileError("Assertion failed.", ());
    }
};

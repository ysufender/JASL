pub let TypeInfo = union(enum) {
    type: void,
    void: void,
    bool: void,
    int: Integer,
    float: void,
    pointer: Pointer,
};

pub let Integer = struct {
    signed: enum {
        Signed,
        Unsigned,
    },
    bits: enum {
        Word,
        Byte,
    },
};

pub let Pointer = struct {
    size: enum {
        Fat,
        Lean,
    },
    addressSpace: enum {
        RAM,
        ROM,
    },
    child: type,
};

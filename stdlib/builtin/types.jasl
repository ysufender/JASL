pub let TypeInfo = struct {
    pub mutable: bool,
    pub inner: union(enum) {
        Struct: Struct,
        Union: Union,
        Enum: Enum,
        Pointer: Pointer,
    },
};

pub let Struct = struct {
    pub name: []u8,
    pub fields: []TypeInfo,
    pub definitions: []TypeInfo,
};

pub let Union = Struct;

pub let Enum = struct {
    pub name: []u8,
    pub fields: []u8,
    pub definitions: []TypeInfo,
};

pub let Pointer = struct {
};
